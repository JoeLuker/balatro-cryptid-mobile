+    -- Android mobile settings (enables mobile UI, disables desktop-only features)
+    if love.system.getOS() == 'Android' then
+        self.F_MOBILE_UI = true
+        self.F_SAVE_TIMER = 30
+        self.F_DISCORD = false
+        self.F_CRASH_REPORTS = false
