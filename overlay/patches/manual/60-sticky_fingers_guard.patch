+-- Guard every sticky_can_* wrapper against a missing optional integration
+-- (Pokermon, Bunco, Reverie, etc.). When the integration is absent its
+-- G.FUNCS.can_X is nil; calling nil crashes on mobile where drag-targets render.
+-- These wrappers are normally injected by lovely/misc_functions.toml (append),
+-- but the lovely dump does not capture that append, so we provide them here
+-- with the nil-guard baked in. -- STICKY_GUARD
+sticky_can_use_blind_card = function(_card)
+    local temp_config = { UIBox = { states = { visible = false } }, config = { ref_table = _card } }
+    if not G.FUNCS.can_use_blind_card then return false end -- STICKY_GUARD
+    G.FUNCS.can_use_blind_card(temp_config)
+    return temp_config.config.button ~= nil
+end
+sticky_can_reserve_card = function(_card)
+    local temp_config = { UIBox = { states = { visible = false } }, config = { ref_table = _card } }
+    if not G.FUNCS.can_reserve_card then return false end -- STICKY_GUARD
+    G.FUNCS.can_reserve_card(temp_config)
+    return temp_config.config.button ~= nil
+end
+sticky_can_select_card = function(_card)
