 function co.forcestop()
@@ -170,6 +171,24 @@
 		G.OVERLAY_MENU:align_to_major()
 		Talisman.scoring_coroutine = _sc
 	end
+	-- OVERLAY_HITBOX: Node:collides_with_point tests against T while drawing
+	-- uses VT; Moveable motion is suppressed during scoring, so the align
+	-- above centres the HITBOXES but the pixels never travel — the overlay
+	-- DRAWS off-centre and the abort button's hitbox sits at the (empty)
+	-- centred position, so taps on the visible button hit the backdrop
+	-- (device tracer: presses logged down=node/ROOM, never down=tal_abort).
+	-- Hard-set VT:=T for the whole overlay tree so drawn = clickable.
+	if G.OVERLAY_MENU then
+		local function tal_hard_set_tree(node, depth)
+			if depth > 25 or not node then return end
+			if node.hard_set_VT then node:hard_set_VT() end
+			if node.UIRoot then tal_hard_set_tree(node.UIRoot, depth + 1) end
+			if type(node.children) == 'table' then
+				for _, ch in pairs(node.children) do tal_hard_set_tree(ch, depth + 1) end
+			end
+		end
+		tal_hard_set_tree(G.OVERLAY_MENU, 0)
+	end
 end
 
