@@ -397,6 +397,21 @@ function Controller:update(dt)
     elseif (self.cursor_hover.target == nil) and self.hovering.target then -- TAP_DESC_PERSIST
         self.hovering.target.states.hover.is = false
         self.hovering.target = nil
+    elseif (self.HID.touch or self.HID.touch_env) and self.is_cursor_down
+        and self.cursor_down.target and self.cursor_down.target.states.hover.can
+        and (self.cursor_down.duration or 0) >= 0.2
+        and (self.cursor_down.distance or 0) < G.MIN_CLICK_DIST then -- TAP_DESC_HOLD_DRAG_HOVER
