+        -- card is nominally being dragged. Switch hover target if it changed.
+        if self.hovering.target and self.hovering.target ~= self.cursor_down.target then
+            self.hovering.target.states.hover.is = false -- vacate previous hover
+        end
+        self.hovering.target = self.cursor_down.target
+        self.hovering.target.states.hover.is = true
+        self.hovering.target:set_offset(self.cursor_hover.T, 'Hover')
     end
 
