+-- SETTINGS_LAYOUT: lay a tab's rows out in two columns so every tab fits on one screen
+-- WITHOUT scrolling. Touch-drag scroll is unusable on this build -- the input engine freezes
+-- the cursor during a finger drag (diagnosed on-device: cursor position constant through an
+-- entire drag), so the menu must never depend on scrolling. Taps (toggles/cycles/buttons) work.
+local function _settings_two_column(rows)
+  local dense = {}
+  for k = 1, #rows do if rows[k] then dense[#dense + 1] = rows[k] end end
+  local n = #dense
+  if n <= 6 then
+    return { n = G.UIT.ROOT, config = { align = "cm", padding = 0.05, colour = G.C.CLEAR },
+      nodes = { { n = G.UIT.C, config = { align = "tm", padding = 0.05 }, nodes = dense } } }
+  end
+  local half = math.ceil(n / 2)
+  local left, right = {}, {}
+  for k = 1, n do
+    if k <= half then left[#left + 1] = dense[k] else right[#right + 1] = dense[k] end
+  end
+  return {
+    n = G.UIT.ROOT, config = { align = "cm", padding = 0.05, colour = G.C.CLEAR },
+    nodes = { { n = G.UIT.R, config = { align = "cm", padding = 0.15 }, nodes = {
+      { n = G.UIT.C, config = { align = "tm", padding = 0.05 }, nodes = left },
+      { n = G.UIT.C, config = { align = "tm", padding = 0.05 }, nodes = right },
+    } } },
+  }
+end
+
 function G.UIDEF.settings_tab(tab)
+  local _root = G.UIDEF._settings_tab_body(tab)
+  if _root and _root.nodes and #_root.nodes > 0 then return _settings_two_column(_root.nodes) end
+  return _root
+end
