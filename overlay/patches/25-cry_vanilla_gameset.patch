+-- CRY_VANILLA_GAMESET: config-tab gameset switcher handlers
+G.FUNCS.cry_cfg_set_gameset = function(e)
+	local _gs = e.config.ref_table and e.config.ref_table.gameset
+	if not _gs then return end
+	G.PROFILES[G.SETTINGS.profile].cry_gameset = _gs
+	G:save_settings()
+end
+G.FUNCS.cry_cfg_gameset_colour = function(e)
+	local _gs = e.config.ref_table and e.config.ref_table.gameset
+	if not _gs then return end
+	local _sel = (G.PROFILES[G.SETTINGS.profile].cry_gameset or "mainline") == _gs
+	e.config.colour = _sel and G.C.CRY_SELECTED or G.C.GREY
+end
